+/*
+ * Canvas pan: hold Mod4 + left-click on the root window and drag to move
+ * the camera freely across the infinite canvas.  All windows reposition
+ * instantly (arrange) on every motion tick, capped at 60 fps.
+ */
 void
-window_unmap(Display *dpy, Window win, Window root, int iconify)
+panmouse(const Arg *arg)
 {
-	static XWindowAttributes ca, ra;
-
-	XGrabServer(dpy);
-	XGetWindowAttributes(dpy, root, &ra);
-	XGetWindowAttributes(dpy, win, &ca);
-
-	/* Prevent UnmapNotify events */
-	XSelectInput(dpy, root, ra.your_event_mask & ~SubstructureNotifyMask);
-	XSelectInput(dpy, win, ca.your_event_mask & ~StructureNotifyMask);
+	int x, y, ox, oy;
+	XEvent ev;
+	Time lasttime = 0;
 
-	XUnmapWindow(dpy, win);
+	if (!getrootptr(&x, &y))
+		return;
+	if (XGrabPointer(dpy, root, False, MOUSEMASK, GrabModeAsync, GrabModeAsync,
+	    None, cursor[CurMove]->cursor, CurrentTime) != GrabSuccess)
+		return;
 
-	if (iconify)
-		window_set_state(dpy, win, IconicState);
+	ox = x; oy = y;
+	do {
+		XMaskEvent(dpy, MOUSEMASK|ExposureMask|SubstructureRedirectMask, &ev);
+		switch (ev.type) {
+		case ConfigureRequest:
+		case Expose:
+		case MapRequest:
+			handler[ev.type](&ev);
+			break;
+		case MotionNotify:
+			if ((ev.xmotion.time - lasttime) <= (1000 / 60))
+				continue;
+			lasttime = ev.xmotion.time;
+			/* pan: drag right moves camera right (vx increases) */
+			selmon->vx -= ev.xmotion.x - ox;
+			selmon->vy -= ev.xmotion.y - oy;
+			ox = ev.xmotion.x;
+			oy = ev.xmotion.y;
+			/* reposition all windows without a full re-layout */
+			arrange(selmon);
+			break;
+		}
+	} while (ev.type != ButtonRelease);
 
-	XSelectInput(dpy, root, ra.your_event_mask);
-	XSelectInput(dpy, win, ca.your_event_mask);
-	XUngrabServer(dpy);
+	XUngrabPointer(dpy, CurrentTime);
+	/* flush any stale EnterNotify events from the pan */
+	while (XCheckMaskEvent(dpy, EnterWindowMask, &ev));
 }
 
