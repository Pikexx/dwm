+/*
+ * Spatial canvas helper: maps a tag bitmask to a viewport (vx, vy) offset.
+ * The 9 standard dwm tags are laid out as a 3x3 grid:
+ *   Tag1(0,0)   Tag2(mw,0)   Tag3(2mw,0)
+ *   Tag4(0,mh)  Tag5(mw,mh)  Tag6(2mw,mh)
+ *   Tag7(0,2mh) Tag8(mw,2mh) Tag9(2mw,2mh)
+ */
+static void
+tagtocanvas(unsigned int tagmask, Monitor *m, int *nvx, int *nvy)
+{
+	int i = 0;
+	unsigned int t = tagmask & TAGMASK;
+	/* find the index of the lowest set bit */
+	while (t > 1) { t >>= 1; i++; }
+	*nvx = (i % 3) * m->mw;
+	*nvy = (i / 3) * m->mh;
+}
