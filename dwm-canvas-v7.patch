 /*
+ * Returns the index (0-based) of the lowest set bit in the monitor's
+ * current tagset.  Used to index tagvx[]/tagvy[] for per-tag viewport.
+ * If multiple tags are visible, the lowest-numbered tag owns the viewport.
+ */
+int
+seltagidx(Monitor *m)
+{
+	unsigned int t = m->tagset[m->seltags] & TAGMASK;
+	int i = 0;
+	if (!t) return 0;
+	while (!(t & 1)) { t >>= 1; i++; }
+	return i;
+}
+
+/*
+ * Smooth ease-out animation: slides the viewport from (fromvx,fromvy) to
+ * (tovx,tovy) over CANVAS_ANIM_FRAMES frames at ~CANVAS_ANIM_MS each.
+ * Repositions all visible windows each frame without re-running the layout.
+ */
+static void
+animatepan(Monitor *m, int fromvx, int fromvy, int tovx, int tovy)
+{
+	Client *c;
+	int step;
+	struct timespec ts = { 0, CANVAS_ANIM_MS * 1000000L };
+
+	for (step = 1; step <= CANVAS_ANIM_FRAMES; step++) {
+		float t    = (float)step / CANVAS_ANIM_FRAMES;
+		float ease = 1.0f - (1.0f - t) * (1.0f - t); /* ease-out quadratic */
+		m->vx = fromvx + (int)((tovx - fromvx) * ease);
+		m->vy = fromvy + (int)((tovy - fromvy) * ease);
+		/* move all managed windows to their canvas-relative positions */
+		for (c = m->clients; c; c = c->next) {
+			if (ISVISIBLE(c))
+				XMoveWindow(dpy, c->win, c->gx - m->vx, c->gy - m->vy);
+		}
+		XFlush(dpy);
+		nanosleep(&ts, NULL);
+	}
+	m->vx = tovx;
+	m->vy = tovy;
+}
